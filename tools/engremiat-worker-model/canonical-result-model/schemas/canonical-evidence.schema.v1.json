{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "engremiat://schemas/canonical-evidence.v1.json",
    "title":  "Canonical Execution Evidence",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "schema_version",
                     "evidence_id",
                     "execution_id",
                     "result_id",
                     "evidence_type",
                     "relative_path",
                     "sha256",
                     "size_bytes",
                     "content_embedded",
                     "secret_values_present",
                     "verified",
                     "created_at"
                 ],
    "properties":  {
                       "schema_version":  {
                                              "const":  "1.0"
                                          },
                       "evidence_id":  {
                                           "type":  "string",
                                           "pattern":  "^EVIDENCE-[A-Z0-9-]+$"
                                       },
                       "execution_id":  {
                                            "type":  "string",
                                            "pattern":  "^EXEC-[A-Z0-9-]+$"
                                        },
                       "result_id":  {
                                         "type":  [
                                                      "string",
                                                      "null"
                                                  ]
                                     },
                       "evidence_type":  {
                                             "enum":  [
                                                          "PROCESS_STDOUT",
                                                          "PROCESS_STDERR",
                                                          "OUTPUT_FILE",
                                                          "VALIDATION_REPORT",
                                                          "AUTHORIZATION",
                                                          "GATE",
                                                          "MANIFEST"
                                                      ]
                                         },
                       "relative_path":  {
                                             "type":  "string",
                                             "minLength":  1
                                         },
                       "sha256":  {
                                      "type":  "string",
                                      "pattern":  "^[A-F0-9]{64}$"
                                  },
                       "size_bytes":  {
                                          "type":  "integer",
                                          "minimum":  0
                                      },
                       "content_embedded":  {
                                                "const":  false
                                            },
                       "secret_values_present":  {
                                                     "const":  false
                                                 },
                       "verified":  {
                                        "type":  "boolean"
                                    },
                       "created_at":  {
                                          "type":  "string",
                                          "minLength":  1
                                      }
                   }
}
