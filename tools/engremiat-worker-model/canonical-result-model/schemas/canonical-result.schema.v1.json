{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "engremiat://schemas/canonical-result.v1.json",
    "title":  "Canonical Worker Result",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "schema_version",
                     "result_id",
                     "execution_id",
                     "task_id",
                     "result_type",
                     "status",
                     "summary",
                     "payload",
                     "payload_sha256",
                     "provider_metadata",
                     "immutable",
                     "created_at"
                 ],
    "properties":  {
                       "schema_version":  {
                                              "const":  "1.0"
                                          },
                       "result_id":  {
                                         "type":  "string",
                                         "pattern":  "^RESULT-[A-Z0-9-]+$"
                                     },
                       "execution_id":  {
                                            "type":  "string",
                                            "pattern":  "^EXEC-[A-Z0-9-]+$"
                                        },
                       "task_id":  {
                                       "type":  "string",
                                       "minLength":  1
                                   },
                       "result_type":  {
                                           "enum":  [
                                                        "STRUCTURED_OUTPUT",
                                                        "TEXT_OUTPUT",
                                                        "PATCH",
                                                        "REPORT",
                                                        "ARTIFACT_SET"
                                                    ]
                                       },
                       "status":  {
                                      "enum":  [
                                                   "PRODUCED",
                                                   "VALIDATED",
                                                   "REJECTED"
                                               ]
                                  },
                       "summary":  {
                                       "type":  "string",
                                       "minLength":  1
                                   },
                       "payload":  {
                                       "type":  "object"
                                   },
                       "payload_sha256":  {
                                              "type":  "string",
                                              "pattern":  "^[A-F0-9]{64}$"
                                          },
                       "provider_metadata":  {
                                                 "type":  "object"
                                             },
                       "immutable":  {
                                         "const":  true
                                     },
                       "created_at":  {
                                          "type":  "string",
                                          "minLength":  1
                                      }
                   }
}
