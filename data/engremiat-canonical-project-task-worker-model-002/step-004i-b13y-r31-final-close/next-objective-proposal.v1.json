{
    "schema_version":  "1.0",
    "proposal_id":  "ENGREMIAT-CONTROLLED-LOCAL-SCRIPT-WORKER-ADAPTER-003",
    "title":  "Controlled Local Script Worker Adapter",
    "status":  "PROPOSED_NOT_STARTED",
    "purpose":  "Connect the canonical Project-Task-Worker engine to the first real but tightly controlled local worker adapter.",
    "strategic_reason":  "A local script adapter is the smallest observable real execution boundary and creates the reusable safety pattern for later Cline and Ollama adapters.",
    "included":  [
                     "Separate execution authorization gate",
                     "Strict operation allowlist",
                     "Local process timeout",
                     "Captured stdout stderr and exit code",
                     "Evidence hash and lifecycle events",
                     "SUCCESS ERROR and CANCELLED handling",
                     "No shell interpolation from untrusted task fields",
                     "No network by default",
                     "Dry-run and simulation parity checks"
                 ],
    "excluded":  [
                     "Cline execution",
                     "Ollama inference",
                     "Remote nodes",
                     "Google APIs",
                     "Telegram execution",
                     "Unrestricted terminal access"
                 ],
    "planned_blocks":  [
                           "Define adapter contract and allowlist",
                           "Build non-executing preflight",
                           "Implement controlled one-command runner",
                           "Integrate canonical lifecycle and evidence",
                           "Run one authorized local smoke",
                           "Audit close and decide Cline or Ollama adapter"
                       ],
    "estimated_safe_blocks":  6,
    "authorization_policy":  "READ_ONLY_PREFLIGHT_NO_PROMPT_REAL_PROCESS_EXECUTION_REQUIRES_EXPLICIT_GATE",
    "recommended_after_completion":  [
                                         "ENGREMIAT_CONTROLLED_CLINE_WORKER_ADAPTER_004",
                                         "ENGREMIAT_CONTROLLED_OLLAMA_WORKER_ADAPTER_005"
                                     ],
