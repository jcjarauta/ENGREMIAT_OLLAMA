                                         },
                       "dependency_type":  {
                                               "type":  "string",
                                               "enum":  [
                                                            "DEPENDS_ON",
                                                            "BLOCKS",
                                                            "PROVIDES_TO",
                                                            "RELATED_TO"
                                                        ]
                                           },
                       "source_id":  {
                                         "type":  "string"
                                     },
                       "source_type":  {
                                           "type":  "string"
                                       },
                       "status":  {
                                      "type":  "string"
                                  },
                       "target_id":  {
                                         "type":  "string"
                                     },
                       "target_type":  {
                                           "type":  "string"
                                       },
                       "summary":  {
