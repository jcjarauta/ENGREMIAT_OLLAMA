                                                    "string",
                                                    "null"
                                                ]
                                   },
                       "purpose":  {
                                       "type":  [
                                                    "string",
                                                    "null"
                                                ]
                                   },
                       "risk":  {
                                    "type":  [
                                                 "string",
                                                 "null"
                                             ]
                                },
                       "priority":  {
                                        "type":  [
                                                     "string",
                                                     "null"
                                                 ]
                                    },
                       "priority_global":  {
                                               "type":  [
                                                            "string",
                                                            "null"
                                                        ]
                                           },
                       "priority_project":  {
                                                "type":  [
                                                             "string",
                                                             "null"
                                                         ]
                                            },
                       "authorization":  {
                                             "type":  [
                                                          "string",
                                                          "null"
                                                      ]
                                         },
                       "validation_state":  {
