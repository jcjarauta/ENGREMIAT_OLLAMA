{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "engremiat://schemas/cline-operation-registry.v1.json",
    "title":  "Engremiat Controlled Cline Operation Registry",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "schema_version",
                     "registry_id",
                     "adapter_id",
                     "source_boundary",
                     "deny_by_default",
                     "free_form_arguments",
                     "raw_prompt_execution",
                     "automatic_continuation",
                     "task_dispatch_enabled",
                     "operation_count",
                     "operations"
                 ],
    "properties":  {
                       "schema_version":  {
                                              "const":  "1.0"
                                          },
                       "registry_id":  {
                                           "type":  "string",
                                           "minLength":  1
                                       },
                       "adapter_id":  {
                                          "const":  "ENGREMIAT-CONTROLLED-CLINE-WORKER-ADAPTER-004"
                                      },
                       "source_boundary":  {
                                               "const":  "CLINE_CLI_COMMAND"
                                           },
                       "deny_by_default":  {
                                               "const":  true
                                           },
                       "free_form_arguments":  {
                                                   "const":  false
                                               },
                       "raw_prompt_execution":  {
                                                    "const":  false
                                                },
                       "automatic_continuation":  {
                                                      "const":  false
                                                  },
                       "task_dispatch_enabled":  {
                                                     "const":  false
                                                 },
                       "operation_count":  {
                                               "type":  "integer",
                                               "minimum":  1
                                           },
                       "operations":  {
                                          "type":  "array",
                                          "minItems":  1
                                      }
                   }
}
