{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "engremiat://schemas/cline-task-envelope.v1.json",
    "title":  "Engremiat Controlled Cline Task Envelope",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "schema_version",
                     "envelope_id",
                     "task_id",
                     "project_id",
                     "objective",
                     "instructions",
                     "repository_scope",
                     "allowed_paths",
                     "forbidden_actions",
                     "validation_contract",
                     "timeout_seconds",
                     "authorization_context",
                     "execution_policy",
                     "dry_run",
                     "runtime_execution"
                 ],
    "properties":  {
                       "schema_version":  {
                                              "const":  "1.0"
                                          },
                       "envelope_id":  {
                                           "type":  "string",
                                           "minLength":  1
                                       },
                       "task_id":  {
                                       "type":  "string",
                                       "minLength":  1
                                   },
                       "project_id":  {
                                          "type":  "string",
                                          "minLength":  1
                                      },
                       "objective":  {
                                         "type":  "string",
                                         "minLength":  1
                                     },
                       "instructions":  {
                                            "type":  "string",
                                            "minLength":  1,
                                            "maxLength":  12000
                                        },
                       "repository_scope":  {
                                                "type":  "string",
                                                "minLength":  1
                                            },
                       "allowed_paths":  {
                                             "type":  "array",
                                             "minItems":  1,
                                             "uniqueItems":  true,
                                             "items":  {
                                                           "type":  "string",
                                                           "minLength":  1
                                                       }
                                         },
                       "forbidden_actions":  {
                                                 "type":  "array",
                                                 "minItems":  1,
                                                 "uniqueItems":  true,
                                                 "items":  {
                                                               "type":  "string",
                                                               "minLength":  1
                                                           }
                                             },
                       "validation_contract":  {
                                                   "type":  "array",
                                                   "minItems":  1,
                                                   "uniqueItems":  true,
                                                   "items":  {
                                                                 "type":  "string",
                                                                 "minLength":  1
                                                             }
                                               },
                       "timeout_seconds":  {
                                               "type":  "integer",
                                               "minimum":  30,
                                               "maximum":  900
                                           },
                       "authorization_context":  {
                                                     "type":  "object",
                                                     "required":  [
                                                                      "task_authorization_state",
                                                                      "execution_authorization_state"
                                                                  ]
                                                 },
                       "execution_policy":  {
                                                "const":  "SINGLE_TASK_CONTROLLED"
                                            },
                       "dry_run":  {
                                       "const":  true
                                   },
                       "runtime_execution":  {
                                                 "const":  false
                                             }
                   }
}
